# --- Terraform ---
# Local state and crash logs (never commit state — it can contain secrets)
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# Provider plugins and local Terraform working dir
.terraform/
.terraform.lock.hcl
# Variable files that may hold secrets
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/

# --- Build artifacts ---
*.zip
build/
dist/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- AWS / secrets ---
.aws/
*.pem
.env
